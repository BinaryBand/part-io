{
  "$defs": {
    "EpisodeStateModel": {
      "additionalProperties": false,
      "description": "Detection state for one episode.",
      "properties": {
        "source_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Hash"
        },
        "open_candidates": {
          "items": {
            "$ref": "#/$defs/MatchModel"
          },
          "title": "Open Candidates",
          "type": "array"
        },
        "close_candidates": {
          "items": {
            "$ref": "#/$defs/MatchModel"
          },
          "title": "Close Candidates",
          "type": "array"
        },
        "intro_candidates": {
          "items": {
            "$ref": "#/$defs/MatchModel"
          },
          "title": "Intro Candidates",
          "type": "array"
        },
        "outro_candidates": {
          "items": {
            "$ref": "#/$defs/MatchModel"
          },
          "title": "Outro Candidates",
          "type": "array"
        },
        "cut": {
          "default": false,
          "title": "Cut",
          "type": "boolean"
        }
      },
      "title": "EpisodeStateModel",
      "type": "object"
    },
    "MatchModel": {
      "additionalProperties": false,
      "description": "A single detection candidate within one episode.",
      "properties": {
        "score": {
          "title": "Score",
          "type": "number"
        },
        "start": {
          "title": "Start",
          "type": "number"
        },
        "end": {
          "title": "End",
          "type": "number"
        },
        "label": {
          "anyOf": [
            {
              "enum": [
                "positive",
                "negative"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Label"
        }
      },
      "required": [
        "score",
        "start",
        "end"
      ],
      "title": "MatchModel",
      "type": "object"
    },
    "RunSettingsModel": {
      "additionalProperties": false,
      "description": "Operational settings persisted in ``[settings]``.\n\nFields marked *-> config* will migrate to ``__config__.toml`` once the new\ndeclarative config is wired in; they remain here for backward compatibility.",
      "properties": {
        "step_seconds": {
          "default": 0.1,
          "title": "Step Seconds",
          "type": "number"
        },
        "workers": {
          "default": 2,
          "title": "Workers",
          "type": "integer"
        },
        "max_matches": {
          "default": 3,
          "title": "Max Matches",
          "type": "integer"
        },
        "fade": {
          "default": 0.5,
          "title": "Fade",
          "type": "number"
        },
        "quiz_size": {
          "default": 10,
          "title": "Quiz Size",
          "type": "integer"
        },
        "no_interactive": {
          "default": false,
          "title": "No Interactive",
          "type": "boolean"
        },
        "overwrite": {
          "default": false,
          "title": "Overwrite",
          "type": "boolean"
        },
        "output_dir": {
          "default": "downloads/remove",
          "title": "Output Dir",
          "type": "string"
        },
        "debug": {
          "default": false,
          "title": "Debug",
          "type": "boolean"
        },
        "snippets_dir": {
          "default": "downloads/snippets",
          "title": "Snippets Dir",
          "type": "string"
        },
        "open_sample": {
          "default": "open.mp3",
          "title": "Open Sample",
          "type": "string"
        },
        "close_sample": {
          "default": "close.mp3",
          "title": "Close Sample",
          "type": "string"
        },
        "intro_sample": {
          "default": "intro.mp3",
          "title": "Intro Sample",
          "type": "string"
        },
        "outro_sample": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Outro Sample"
        },
        "min_gap": {
          "default": -15.0,
          "title": "Min Gap",
          "type": "number"
        },
        "max_gap": {
          "default": 300.0,
          "title": "Max Gap",
          "type": "number"
        },
        "ad_inclusive": {
          "default": true,
          "title": "Ad Inclusive",
          "type": "boolean"
        },
        "intro_exclusive": {
          "default": true,
          "title": "Intro Exclusive",
          "type": "boolean"
        }
      },
      "title": "RunSettingsModel",
      "type": "object"
    },
    "SegmentModel": {
      "additionalProperties": false,
      "description": "A confirmed positive or negative snippet hit stored in the target list.",
      "properties": {
        "source": {
          "title": "Source",
          "type": "string"
        },
        "start": {
          "title": "Start",
          "type": "number"
        },
        "end": {
          "title": "End",
          "type": "number"
        },
        "score": {
          "title": "Score",
          "type": "number"
        }
      },
      "required": [
        "source",
        "start",
        "end",
        "score"
      ],
      "title": "SegmentModel",
      "type": "object"
    },
    "TargetStateModel": {
      "additionalProperties": false,
      "description": "Accumulated positive/negative examples for one snippet type.\n\nUsed both here (legacy ``[targets.*]`` in state) and in ``AudioSnippetModel``\n(new design, embedded per snippet in config).",
      "properties": {
        "positives": {
          "items": {
            "$ref": "#/$defs/SegmentModel"
          },
          "title": "Positives",
          "type": "array"
        },
        "negatives": {
          "items": {
            "$ref": "#/$defs/SegmentModel"
          },
          "title": "Negatives",
          "type": "array"
        }
      },
      "title": "TargetStateModel",
      "type": "object"
    },
    "TargetsByKindModel": {
      "additionalProperties": false,
      "description": "Legacy top-level target banks persisted as ``[targets.open]`` / ``close``.",
      "properties": {
        "open": {
          "$ref": "#/$defs/TargetStateModel"
        },
        "close": {
          "$ref": "#/$defs/TargetStateModel"
        }
      },
      "title": "TargetsByKindModel",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Root model for ``__state__.toml``.",
  "properties": {
    "targets": {
      "$ref": "#/$defs/TargetsByKindModel"
    },
    "settings": {
      "$ref": "#/$defs/RunSettingsModel"
    },
    "episodes": {
      "additionalProperties": {
        "$ref": "#/$defs/EpisodeStateModel"
      },
      "title": "Episodes",
      "type": "object"
    }
  },
  "title": "PipelineStateModel",
  "type": "object"
}
