{
  "$defs": {
    "EpisodeStateModel": {
      "additionalProperties": false,
      "description": "Detection state for one episode.",
      "properties": {
        "close_candidates": {
          "items": {
            "$ref": "#/$defs/MatchModel"
          },
          "title": "Close Candidates",
          "type": "array"
        },
        "cut": {
          "default": false,
          "title": "Cut",
          "type": "boolean"
        },
        "intro_candidates": {
          "items": {
            "$ref": "#/$defs/MatchModel"
          },
          "title": "Intro Candidates",
          "type": "array"
        },
        "open_candidates": {
          "items": {
            "$ref": "#/$defs/MatchModel"
          },
          "title": "Open Candidates",
          "type": "array"
        },
        "outro_candidates": {
          "items": {
            "$ref": "#/$defs/MatchModel"
          },
          "title": "Outro Candidates",
          "type": "array"
        },
        "source_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Hash"
        }
      },
      "title": "EpisodeStateModel",
      "type": "object"
    },
    "MatchModel": {
      "additionalProperties": false,
      "description": "A single detection candidate within one episode.",
      "properties": {
        "end": {
          "title": "End",
          "type": "number"
        },
        "label": {
          "anyOf": [
            {
              "enum": [
                "positive",
                "negative"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Label"
        },
        "score": {
          "title": "Score",
          "type": "number"
        },
        "start": {
          "title": "Start",
          "type": "number"
        }
      },
      "required": [
        "score",
        "start",
        "end"
      ],
      "title": "MatchModel",
      "type": "object"
    },
    "RunSettingsModel": {
      "additionalProperties": false,
      "description": "Operational settings persisted in ``[settings]``.",
      "properties": {
        "ad_inclusive": {
          "default": true,
          "title": "Ad Inclusive",
          "type": "boolean"
        },
        "debug": {
          "default": false,
          "title": "Debug",
          "type": "boolean"
        },
        "fade": {
          "default": 0.5,
          "title": "Fade",
          "type": "number"
        },
        "intro_exclusive": {
          "default": true,
          "title": "Intro Exclusive",
          "type": "boolean"
        },
        "max_gap": {
          "default": 300.0,
          "title": "Max Gap",
          "type": "number"
        },
        "max_matches": {
          "default": 3,
          "title": "Max Matches",
          "type": "integer"
        },
        "min_gap": {
          "default": -15.0,
          "title": "Min Gap",
          "type": "number"
        },
        "output_dir": {
          "default": "downloads/remove",
          "title": "Output Dir",
          "type": "string"
        },
        "overwrite": {
          "default": false,
          "title": "Overwrite",
          "type": "boolean"
        },
        "quiz_size": {
          "default": 10,
          "title": "Quiz Size",
          "type": "integer"
        },
        "step_seconds": {
          "default": 0.1,
          "title": "Step Seconds",
          "type": "number"
        },
        "workers": {
          "default": 2,
          "title": "Workers",
          "type": "integer"
        }
      },
      "title": "RunSettingsModel",
      "type": "object"
    },
    "SegmentModel": {
      "additionalProperties": false,
      "description": "A confirmed positive or negative snippet hit stored in the target list.",
      "properties": {
        "end": {
          "title": "End",
          "type": "number"
        },
        "score": {
          "title": "Score",
          "type": "number"
        },
        "start": {
          "title": "Start",
          "type": "number"
        },
        "stem": {
          "title": "Stem",
          "type": "string"
        }
      },
      "required": [
        "stem",
        "start",
        "end",
        "score"
      ],
      "title": "SegmentModel",
      "type": "object"
    },
    "SnippetProfileStateModel": {
      "additionalProperties": false,
      "description": "Embedded detection profile stored under ``[snippets.profile]``.",
      "properties": {
        "analysis_rate": {
          "title": "Analysis Rate",
          "type": "integer"
        },
        "band_count": {
          "title": "Band Count",
          "type": "integer"
        },
        "data": {
          "title": "Data",
          "type": "string"
        },
        "hop_size": {
          "title": "Hop Size",
          "type": "integer"
        },
        "n_frames": {
          "title": "N Frames",
          "type": "integer"
        }
      },
      "required": [
        "n_frames",
        "analysis_rate",
        "hop_size",
        "band_count",
        "data"
      ],
      "title": "SnippetProfileStateModel",
      "type": "object"
    },
    "SnippetStateModel": {
      "additionalProperties": false,
      "description": "One snippet entry in the ``[[snippets]]`` array-of-tables.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "profile": {
          "$ref": "#/$defs/SnippetProfileStateModel"
        }
      },
      "required": [
        "name",
        "profile"
      ],
      "title": "SnippetStateModel",
      "type": "object"
    },
    "TargetStateModel": {
      "additionalProperties": false,
      "description": "Accumulated positive/negative examples for one snippet type.",
      "properties": {
        "negatives": {
          "items": {
            "$ref": "#/$defs/SegmentModel"
          },
          "title": "Negatives",
          "type": "array"
        },
        "positives": {
          "items": {
            "$ref": "#/$defs/SegmentModel"
          },
          "title": "Positives",
          "type": "array"
        }
      },
      "title": "TargetStateModel",
      "type": "object"
    },
    "TargetsByKindModel": {
      "additionalProperties": false,
      "description": "Top-level target banks persisted as ``[targets.open]`` / ``[targets.close]``.",
      "properties": {
        "close": {
          "$ref": "#/$defs/TargetStateModel"
        },
        "open": {
          "$ref": "#/$defs/TargetStateModel"
        }
      },
      "title": "TargetsByKindModel",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Root model for ``__state__.toml``.",
  "properties": {
    "episodes": {
      "additionalProperties": {
        "$ref": "#/$defs/EpisodeStateModel"
      },
      "title": "Episodes",
      "type": "object"
    },
    "settings": {
      "$ref": "#/$defs/RunSettingsModel"
    },
    "snippets": {
      "items": {
        "$ref": "#/$defs/SnippetStateModel"
      },
      "title": "Snippets",
      "type": "array"
    },
    "targets": {
      "$ref": "#/$defs/TargetsByKindModel"
    }
  },
  "title": "PipelineStateModel",
  "type": "object"
}
