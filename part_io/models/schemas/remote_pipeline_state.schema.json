{
  "$defs": {
    "EpisodeStateModel": {
      "additionalProperties": false,
      "description": "Detection state for one episode.\n\n``candidates`` and ``classes`` are keyed by snippet name (e.g. ``\"open\"``,\n``\"close\"``, ``\"intro\"``), mirroring the runtime ``EpisodeState`` dataclass.",
      "properties": {
        "candidates": {
          "additionalProperties": {
            "items": {
              "$ref": "#/$defs/MatchModel"
            },
            "type": "array"
          },
          "title": "Candidates",
          "type": "object"
        },
        "classes": {
          "additionalProperties": {
            "enum": [
              "positive",
              "negative",
              "uncertain",
              "undetected"
            ],
            "type": "string"
          },
          "title": "Classes",
          "type": "object"
        },
        "cut": {
          "default": false,
          "title": "Cut",
          "type": "boolean"
        },
        "source": {
          "default": "",
          "title": "Source",
          "type": "string"
        },
        "source_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Hash"
        }
      },
      "title": "EpisodeStateModel",
      "type": "object"
    },
    "MatchModel": {
      "additionalProperties": false,
      "description": "A single detection candidate within one episode.",
      "properties": {
        "end": {
          "title": "End",
          "type": "number"
        },
        "score": {
          "title": "Score",
          "type": "number"
        },
        "start": {
          "title": "Start",
          "type": "number"
        }
      },
      "required": [
        "score",
        "start",
        "end"
      ],
      "title": "MatchModel",
      "type": "object"
    },
    "RunSettingsModel": {
      "additionalProperties": false,
      "description": "Operational settings persisted in ``[settings]``.\n\nFields marked *\u2192 config* will migrate to ``__config__.toml`` once the new\ndeclarative config is wired in; they remain here for backward compatibility.",
      "properties": {
        "ad_inclusive": {
          "default": true,
          "title": "Ad Inclusive",
          "type": "boolean"
        },
        "close_sample": {
          "default": "close.mp3",
          "title": "Close Sample",
          "type": "string"
        },
        "debug": {
          "default": false,
          "title": "Debug",
          "type": "boolean"
        },
        "fade": {
          "default": 0.5,
          "title": "Fade",
          "type": "number"
        },
        "intro_exclusive": {
          "default": true,
          "title": "Intro Exclusive",
          "type": "boolean"
        },
        "intro_sample": {
          "default": "intro.mp3",
          "title": "Intro Sample",
          "type": "string"
        },
        "max_gap": {
          "default": 300.0,
          "title": "Max Gap",
          "type": "number"
        },
        "max_matches": {
          "default": 3,
          "title": "Max Matches",
          "type": "integer"
        },
        "min_gap": {
          "default": -15.0,
          "title": "Min Gap",
          "type": "number"
        },
        "no_interactive": {
          "default": false,
          "title": "No Interactive",
          "type": "boolean"
        },
        "open_sample": {
          "default": "open.mp3",
          "title": "Open Sample",
          "type": "string"
        },
        "output_dir": {
          "default": "downloads/remove",
          "title": "Output Dir",
          "type": "string"
        },
        "outro_sample": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Outro Sample"
        },
        "overwrite": {
          "default": false,
          "title": "Overwrite",
          "type": "boolean"
        },
        "quiz_size": {
          "default": 10,
          "title": "Quiz Size",
          "type": "integer"
        },
        "snippets_dir": {
          "default": "downloads/snippets",
          "title": "Snippets Dir",
          "type": "string"
        },
        "step_seconds": {
          "default": 0.1,
          "title": "Step Seconds",
          "type": "number"
        },
        "workers": {
          "default": 2,
          "title": "Workers",
          "type": "integer"
        }
      },
      "title": "RunSettingsModel",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Root model for ``__state__.toml``.",
  "properties": {
    "episodes": {
      "additionalProperties": {
        "$ref": "#/$defs/EpisodeStateModel"
      },
      "title": "Episodes",
      "type": "object"
    },
    "settings": {
      "$ref": "#/$defs/RunSettingsModel"
    }
  },
  "title": "PipelineStateModel",
  "type": "object"
}
